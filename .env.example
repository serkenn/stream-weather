# ===== 必須 =====
# YouTube Studio →「ライブ配信」→「ストリームキー」をコピーして貼る
YOUTUBE_STREAM_KEY=xxxx-xxxx-xxxx-xxxx-xxxx

# ===== 解像度 / フレームレート =====
# 既定 1080p（GPUなし・CPUエンコードでの現実的な上限）:
OUTPUT_W=1920
OUTPUT_H=1080
# 4K にする場合（高性能CPU、できればGPU推奨）:
# OUTPUT_W=3840
# OUTPUT_H=2160
# 8K にする場合（GPUエンコード・大帯域回線がほぼ必須）:
# OUTPUT_W=7680
# OUTPUT_H=4320
FPS=30

# ===== エンコード =====
# CPU(汎用): libx264 ／ GPU(NVIDIA): h264_nvenc, hevc_nvenc
VIDEO_ENCODER=libx264
# CPU負荷と画質のバランス。重ければ faster→fast→ultrafast の順で軽くなる
X264_PRESET=veryfast
# ビットレート目安: 1080p30=6000k / 4K=16000k / 8K=45000k 以上
VIDEO_BITRATE=6000k
AUDIO_BITRATE=128k

# ===== その他 =====
# 配信先（通常はYouTube既定のまま）
RTMP_URL=rtmp://a.rtmp.youtube.com/live2
# 気象庁データの取得間隔（分）
UPDATE_INTERVAL_MIN=10
# ダッシュボードのポート
PORT=8080
# 高DPIで文字を大きくしたい場合に 1.5 など
SCALE=1
